# Copy this file to .env and fill in your credentials

# Hugging Face token (for Qwen2.5 via Inference API)
# Free at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Groq API key (for Llama 3.3 70B — frontier model + evaluation judge)
# FREE tier: 1,000 req/day, 30 RPM — no billing required
# Get yours at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
